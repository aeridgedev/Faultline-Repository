; Engine configuration file.
; Faultline — 2D multiplayer survival Battle Royale (Godot 4 / GDScript)
;
; Locked decisions live in:
;   src/core/Constants.gd   (enums + structural constants)
;   data/*.json             (tunable balance values — TBD pass)

config_version=5

[application]

config/name="Faultline"
config/description="Competitive 2D multiplayer survival Battle Royale. Up to 100 players descend through a procedurally generated underground planet; last survivor wins. 18-22 min matches."
run/main_scene="res://src/core/Main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://assets/ui/icon.svg"

[autoload]

Constants="*res://src/core/Constants.gd"
GameManager="*res://src/core/GameManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="Faultline"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0

